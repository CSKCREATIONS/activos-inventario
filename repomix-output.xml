            LEFT JOIN equipos  e ON d.equipo_id  = e.id
            LEFT JOIN usuarios u ON d.usuario_id = u.id
            WHERE 1=1
        """
        params = []

        if busqueda:
            sql += " AND (d.nombre LIKE %s OR d.tipo LIKE %s)"
            q = f"%{busqueda}%"
            params.extend([q, q])
        if tipo:
            sql += " AND d.tipo = %s"
