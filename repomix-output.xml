            asignacion["usuario_principal_nombre"] = usuario_principal.get("nombre", "")

        usuarios_ids = asignacion.get("usuarios_ids", [])
        usuarios_extra = []
        for uid in usuarios_ids:
            u = await UsuarioModel.find_by_id(uid)
