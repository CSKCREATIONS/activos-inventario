from fastapi import APIRouter, Depends, HTTPException, Query
from datetime import date, datetime
import uuid
from config.db import get_pool
from dependencies import get_current_user
from utils.audit import log_action
from utils.serializer import serialize
from models.suministro import SuministroModel

router = APIRouter()

# ──────────────────────────────────────────────────────────────────────────────
# MODELO DE MOVIMIENTOS (operaciones directas sin crear un modelo separado)
# ──────────────────────────────────────────────────────────────────────────────

async def registrar_movimiento(
    suministro_id: str,
    tipo: str,          # 'entrada' o 'salida'
    cantidad: int,
    usuario_sistema_id: str,
    motivo: str,
    usuario_solicitante_id: str = None,
    area_solicitante: str = None,
    comprobante: str = None,
    observaciones: str = None
) -> dict:
    """Registra un movimiento y actualiza el stock del suministro."""
    if cantidad <= 0:
        raise ValueError("La cantidad debe ser positiva")
    
    pool = await get_pool()
    async with pool.acquire() as conn:
        async with conn.cursor() as cur:
            # 1. Obtener stock actual del suministro
            await cur.execute("SELECT cantidad FROM suministros WHERE id = %s", (suministro_id,))
            row = await cur.fetchone()
            if not row:
                raise ValueError("Suministro no encontrado")
            stock_actual = row["cantidad"]
            
            # 2. Validar stock suficiente para salida
            if tipo == "salida" and stock_actual < cantidad:
                raise ValueError(f"Stock insuficiente. Disponible: {stock_actual}, solicitado: {cantidad}")
            
            # 3. Calcular nuevo stock
            nuevo_stock = stock_actual + cantidad if tipo == "entrada" else stock_actual - cantidad
            
            # 4. Insertar movimiento
            movimiento_id = str(uuid.uuid4())
            await cur.execute(
                """INSERT INTO movimientos_suministros
                   (id, suministro_id, tipo_movimiento, cantidad, usuario_sistema_id,
                    usuario_solicitante_id, area_solicitante, motivo, comprobante, observaciones)
                   VALUES (%s, %s, %s, %s, %s, %s, %s, %s, %s, %s)""",
                (movimiento_id, suministro_id, tipo, cantidad, usuario_sistema_id,
                 usuario_solicitante_id, area_solicitante, motivo, comprobante, observaciones)
            )
            
            # 5. Actualizar stock en suministros
            await cur.execute(
                "UPDATE suministros SET cantidad = %s WHERE id = %s",
                (nuevo_stock, suministro_id)
            )
    
    return {
        "id": movimiento_id,
        "suministro_id": suministro_id,
        "tipo": tipo,
        "cantidad": cantidad,
        "nuevo_stock": nuevo_stock,
        "fecha": datetime.now().isoformat()
    }

async def obtener_movimientos(suministro_id: str, limit: int = 100, offset: int = 0) -> list:
    pool = await get_pool()
    async with pool.acquire() as conn:
        async with conn.cursor() as cur:
            await cur.execute(
                """SELECT m.*, u.username as usuario_nombre, u.nombre as usuario_sistema_nombre,
                          sol.nombre as solicitante_nombre
                   FROM movimientos_suministros m
                   LEFT JOIN usuarios_sistema u ON m.usuario_sistema_id = u.id
                   LEFT JOIN usuarios sol ON m.usuario_solicitante_id = sol.id
                   WHERE m.suministro_id = %s
                   ORDER BY m.fecha DESC
                   LIMIT %s OFFSET %s""",
                (suministro_id, limit, offset)
            )
            return await cur.fetchall()

# ──────────────────────────────────────────────────────────────────────────────
# ENDPOINTS
# ──────────────────────────────────────────────────────────────────────────────

@router.post("/{suministro_id}/movimientos", status_code=201)
async def crear_movimiento(
    suministro_id: str,
    body: dict,
    current_user: dict = Depends(get_current_user)
):
    """
    Registra una entrada o salida de inventario para un suministro.
    Body: {
        "tipo": "entrada" | "salida",
        "cantidad": int,
        "motivo": "Compra" | "Ajuste" | "Asignación a equipo" | "Entrega a área" | "Baja" | "Vencimiento",
        "usuario_solicitante_id": (opcional),
        "area_solicitante": (opcional),
        "comprobante": (opcional),
        "observaciones": (opcional)
    }
    """
    tipo = body.get("tipo")
    cantidad = body.get("cantidad")
    motivo = body.get("motivo")
    usuario_solicitante_id = body.get("usuario_solicitante_id")
    area_solicitante = body.get("area_solicitante")
    comprobante = body.get("comprobante")
    observaciones = body.get("observaciones")

    if tipo not in ("entrada", "salida"):
        raise HTTPException(status_code=400, detail="tipo debe ser 'entrada' o 'salida'")
    if not cantidad or cantidad <= 0:
        raise HTTPException(status_code=400, detail="cantidad debe ser un número positivo")
    if not motivo:
        raise HTTPException(status_code=400, detail="motivo es requerido")

    user_id = current_user.get("sub") or current_user.get("id")
    if not user_id:
        raise HTTPException(status_code=400, detail="No se pudo identificar el usuario autenticado")

    try:
        movimiento = await registrar_movimiento(
            suministro_id=suministro_id,
            tipo=tipo,
            cantidad=cantidad,
            usuario_sistema_id=user_id,
            motivo=motivo,
            usuario_solicitante_id=usuario_solicitante_id,
            area_solicitante=area_solicitante,
            comprobante=comprobante,
            observaciones=observaciones
        )
        
        # Auditoría
        await log_action(
            user_id=user_id,
            accion=f"Registró {tipo} de suministro",
            modulo="Suministros",
            entidad_id=suministro_id,
            detalle=f"Movimiento: {tipo} de {cantidad} unidades, motivo: {motivo}"
        )
        
        return serialize({"data": movimiento, "message": "Movimiento registrado exitosamente"})
    except ValueError as e:
        raise HTTPException(status_code=409, detail=str(e))
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))

@router.get("/{suministro_id}/movimientos")
async def listar_movimientos(
    suministro_id: str,
    limit: int = Query(100, ge=1, le=500),
    offset: int = Query(0, ge=0),
    current_user: dict = Depends(get_current_user)
):
    """Obtiene el historial de movimientos de un suministro."""
    # Verificar que el suministro existe
    suministro = await SuministroModel.find_by_id(suministro_id)
    if not suministro:
        raise HTTPException(status_code=404, detail="Suministro no encontrado")
    
    movimientos = await obtener_movimientos(suministro_id, limit, offset)
    return serialize({"data": movimientos, "total": len(movimientos)})

@router.get("/{suministro_id}/kardex")
async def obtener_kardex(
    suministro_id: str,
    current_user: dict = Depends(get_current_user)
):
    """Devuelve el stock actual y el historial completo de movimientos."""
    suministro = await SuministroModel.find_by_id(suministro_id)
    if not suministro:
        raise HTTPException(status_code=404, detail="Suministro no encontrado")
    
    movimientos = await obtener_movimientos(suministro_id, limit=1000, offset=0)
    
    # Calcular saldo por cada movimiento (opcional)
    saldo = 0
    for m in movimientos:
        if m["tipo_movimiento"] == "entrada":
            saldo += m["cantidad"]
        else:
            saldo -= m["cantidad"]
        m["saldo_parcial"] = saldo
    
    return serialize({
        "data": {
            "suministro": suministro,
            "stock_actual": suministro["cantidad"],
            "movimientos": movimientos
        }
    })
