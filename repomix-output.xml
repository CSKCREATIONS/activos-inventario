    firma_base64 = body.get("firma")
    if not usuario_id or not firma_base64:
        raise HTTPException(status_code=400, detail="Se requiere usuario_id y firma")

    from models.usuario import UsuarioModel
    usuario = await UsuarioModel.find_by_id(usuario_id)
    if not usuario:
        raise HTTPException(status_code=404, detail="Usuario no encontrado")
    nombre_usuario = usuario["nombre"]

    firmas = asignacion.get("firmas") or []
    if isinstance(firmas, str):
        firmas = json.loads(firmas)
    if any(f["user_id"] == usuario_id for f in firmas):
        raise HTTPException(status_code=400, detail="Este usuario ya ha firmado")

