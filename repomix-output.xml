  // ── Campos Hoja de Vida ──────────────────────────────
  procesador?: string;
  nombre_equipo?: string;
  licenciamiento_so?: string;
  licenciamiento_office?: string;
  marca_monitor?: string;
  placa_monitor?: string;  // ── Mantenimiento ─────────────────────────────────────────
  ultimo_mantenimiento?: string | null;}
  

